{
  "name": "@ruslanlap/pagespeed-insights-mcp",
  "version": "1.2.6",
  "description": "MCP server for Google PageSpeed Insights & Chrome UX Report APIs — 16 tools to analyze, compare, and optimize web performance with Claude, Cursor, or any MCP-compatible AI client",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "bin": {
    "pagespeed-insights-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "pagespeed",
    "pagespeed-insights",
    "performance",
    "web-performance",
    "core-web-vitals",
    "crux",
    "chrome-ux-report",
    "google",
    "lighthouse",
    "lighthouse-ci",
    "claude",
    "cursor",
    "model-context-protocol",
    "seo",
    "accessibility",
    "ai-tools",
    "lcp",
    "fcp",
    "cls",
    "ttfb"
  ],
  "author": "PageSpeed Insights MCP Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruslanlap/pagespeed-insights-mcp.git"
  },
  "homepage": "https://github.com/ruslanlap/pagespeed-insights-mcp#readme",
  "bugs": {
    "url": "https://github.com/ruslanlap/pagespeed-insights-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-fetch": "^3.3.2",
    "p-limit": "^7.3.0",
    "p-retry": "^6.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.0.12",
    "eslint": "^8.57.0",
    "nock": "^13.5.0",
    "prettier": "^3.2.5",
    "semantic-release": "^25.0.8",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.0.12"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
