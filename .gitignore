**/.gnupg/**
**/.pgp/

# npm / yarn / pnpm authentication (tokens can live here)
.npmrc
.yarnrc.yml
.yarnrc
.pnpmrc
**/.npm/_auth
**/.npmrc

# Git credentials & tokens
.git-credentials
.gitconfig.local
.ghc/
